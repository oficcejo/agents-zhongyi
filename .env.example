# ============================================================
# 中医智能诊疗系统 - 环境变量配置模板
# 复制本文件为 .env 并填入你的 API Key
# ============================================================

# DeepSeek API 配置（必填 - 7-Agent 诊疗流水线）
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 多模态视觉模型配置（选填 - AI望诊：面色/舌象分析）
VISION_API_KEY=your-vision-api-key
VISION_API_BASE=https://api.openai.com/v1
VISION_MODEL=gpt-4o

# 语音识别配置（选填 - 问诊语音转文字，当前版本使用文本输入）
ASR_API_KEY=your-asr-api-key
ASR_API_BASE=https://api.openai.com/v1
ASR_MODEL=whisper-1

# 语音合成配置（选填 - 追问语音播放）
TTS_API_KEY=your-tts-api-key
TTS_API_BASE=https://api.openai.com/v1
TTS_MODEL=tts-1

# ============================================================
# 兼容服务说明
# 以上所有 API 均支持 OpenAI 兼容格式，可替换为：
# - DeepSeek: https://api.deepseek.com/v1
# - 长猫 LongCat: https://api.longcat.chat/openai
# - 小米 MiMo: https://token-plan-cn.xiaomimimo.com/v1
# - 本地 Ollama: http://localhost:11434/v1
# - 其他 OpenAI 兼容服务
# ============================================================
